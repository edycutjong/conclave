# ── Conclave (Vouch) — environment ──────────────────────────────────────────
# Copy to .env.local for Next.js (server-only) and .env for scripts. NEVER commit real values.

# Demo mode is ON by default. Set to "false" to wire reads + execute to live Testnet
# (requires CSPR_CLOUD_API_KEY, a funded key at CASPER_ORCHESTRATOR_SECRET_KEY_PATH,
# and a deployed CONCLAVE_CONTRACT_HASH). See LIVE_TESTNET.md.
CONCLAVE_DEMO=true
# Signing key algorithm for casper-js-sdk (ed25519 | secp256k1)
CASPER_KEY_ALGO=ed25519

# Anthropic (the council). Set ANTHROPIC_API_KEY to run the REAL multi-agent council —
# 3 role agents on Haiku 4.5 + an Arbiter on Opus 4.8, grounded by on-chain reads and
# guard-railed by the deterministic reconcile() baseline (src/agents/llm.ts).
# With no key, the council degrades to the deterministic demo engine (still fully interactive).
ANTHROPIC_API_KEY=
CONCLAVE_ARBITER_MODEL=claude-opus-4-8
CONCLAVE_ROLE_MODEL=claude-haiku-4-5

# CSPR.cloud access token — obtain at https://cspr.cloud/ . Used as: Authorization: $CSPR_CLOUD_API_KEY
# Do NOT put this in any client/browser bundle.
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_REST_URL=https://node.testnet.cspr.cloud
# CSPR.cloud REST API (indexed data) — used for grounded reads in src/agents/tools/mcp.ts.
CSPR_CLOUD_API_URL=https://api.testnet.cspr.cloud

# Casper Testnet (CAIP-2 casper:casper-test)
CASPER_NETWORK=casper-test
CASPER_NODE_RPC=https://node.testnet.cspr.cloud/rpc
CASPER_CHAIN_NAME=casper-test

# Casper MCP server (msanlisavas/casper-mcp, run via Docker) — base URL the agents call as tools.
CASPER_MCP_URL=http://localhost:8080

# Orchestrator signing key (the council's deploy key). Testnet only — committed keypairs
# live under data/keys/ for the deterministic demo; production keys go here.
CASPER_ORCHESTRATOR_SECRET_KEY_PATH=./data/keys/orchestrator_secret_key.pem
CONCLAVE_CONTRACT_HASH=

# Governance params (mirror the on-chain init)
CONCLAVE_QUORUM=2
CONCLAVE_VETO_WINDOW_SECONDS=45

# ── Optional overrides (sensible defaults; uncomment only to tune) ────────────
# CASPER_CALL_PAYMENT_MOTES=5000000000   # gas limit per contract entry-point call (default 5 CSPR)
